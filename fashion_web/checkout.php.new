<?php
if (session_status() === PHP_SESSION_NONE) {
    session_start();
}
include 'components/connect.php';

// Check if cart is empty first
include 'check_cart.php';

// Initialize guest session if not logged in
if (!isset($_SESSION['user_id']) && !isset($_COOKIE['user_id'])) {
    if (!isset($_SESSION['guest_id'])) {
        $_SESSION['guest_id'] = 'GUEST_' . time() . bin2hex(random_bytes(8));
    }
    $user_id = $_SESSION['guest_id'];
    $is_guest = true;
} else {
    $user_id = $_SESSION['user_id'] ?? $_COOKIE['user_id'];
    $is_guest = false;
}

// Initialize cart for guests if not exists
if ($is_guest && !isset($_SESSION['cart'])) {
    $_SESSION['cart'] = [];
}

if(isset($_POST['place_order'])) {
    // Sanitize and validate input
    $name = htmlspecialchars(trim($_POST['name']));
    $number = preg_replace('/[^0-9]/', '', $_POST['number']);
    $email = filter_var($_POST['email'], FILTER_SANITIZE_EMAIL);
    $method = htmlspecialchars(trim($_POST['method']));
    $address_type = htmlspecialchars(trim($_POST['address_type']));
    $flat = htmlspecialchars(trim($_POST['flat']));
    $street = htmlspecialchars(trim($_POST['street']));
    $city = htmlspecialchars(trim($_POST['city']));
    $country = htmlspecialchars(trim($_POST['country']));
    $pincode = preg_replace('/[^0-9]/', '', $_POST['pincode']);
    
    $validation_passed = true;
    
    // Validate email
    if (!filter_var($email, FILTER_VALIDATE_EMAIL)) {
        $warning_msg[] = 'Invalid email address!';
        $validation_passed = false;
    }
    
    // Validate phone number length
    if (strlen($number) < 10 || strlen($number) > 15) {
        $warning_msg[] = 'Invalid phone number!';
        $validation_passed = false;
    }
    
    // Validate pincode
    if (strlen($pincode) != 6) {
        $warning_msg[] = 'Invalid pincode!';
        $validation_passed = false;
    }
    
    if (!$validation_passed) {
        // Skip the rest of the order processing
    } else {
        $address = $flat .', '. $street .', '. $city .', '. $country .' - '. $pincode;

        $order_products = '';
        $grand_total = 0;

        // Get cart items and calculate total
        try {
            $order_items = [];
            
            if (!$is_guest) {
                // Get cart items from database for logged-in users
                $select_cart = $conn->prepare("SELECT c.*, p.name, p.price, p.stock FROM `cart` c JOIN `products` p ON c.product_id = p.id WHERE c.user_id = ?");
                $select_cart->execute([$user_id]);
                
                if($select_cart->rowCount() > 0){
                    while($fetch_cart = $select_cart->fetch(PDO::FETCH_ASSOC)){
                        // Verify stock availability
                        if($fetch_cart['qty'] > $fetch_cart['stock']) {
                            $warning_msg[] = "Sorry, {$fetch_cart['name']} only has {$fetch_cart['stock']} items in stock!";
                            $validation_passed = false;
                            break;
                        }
                        
                        $order_items[] = [
                            'product_id' => $fetch_cart['product_id'],
                            'name' => $fetch_cart['name'],
                            'qty' => $fetch_cart['qty'],
                            'price' => $fetch_cart['price']
                        ];
                        
                        $grand_total += ($fetch_cart['price'] * $fetch_cart['qty']);
                    }
                }
            } else {
                // Get cart items from session for guest users
                if (isset($_SESSION['cart']) && !empty($_SESSION['cart'])) {
                    foreach ($_SESSION['cart'] as $product_id) {
                        $select_product = $conn->prepare("SELECT * FROM products WHERE id = ?");
                        $select_product->execute([$product_id]);
                        $product = $select_product->fetch(PDO::FETCH_ASSOC);
                        if ($product) {
                            // For guests, quantity is always 1
                            if ($product['stock'] < 1) {
                                $warning_msg[] = "Sorry, {$product['name']} is out of stock!";
                                $validation_passed = false;
                                break;
                            }

                            $order_items[] = [
                                'product_id' => $product_id,
                                'name' => $product['name'],
                                'price' => $product['price'],
                                'qty' => 1
                            ];
                            $grand_total += $product['price'];
                        }
                    }
                }
            }
            
            if (empty($order_items)) {
                $warning_msg[] = 'Your cart is empty!';
                $validation_passed = false;
            }

            if($grand_total > 0 && $validation_passed) {
                try {
                    $conn->beginTransaction();
                    
                    // Generate a more secure order ID
                    $order_id = 'ORD' . time() . bin2hex(random_bytes(4));
                    
                    // Insert into orders table
                    $insert_order = $conn->prepare("INSERT INTO `orders` (id, user_id, name, number, email, method, address, order_details, total_price, address_type, order_status, payment_status, is_guest, created_at) VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?)");
                    $insert_order->execute([
                        $order_id,
                        $user_id,
                        $name,
                        $number,
                        $email,
                        $method,
                        $address,
                        json_encode($order_items),
                        $grand_total,
                        $address_type,
                        'processing',
                        'pending',
                        $is_guest ? 1 : 0,
                        date('Y-m-d H:i:s')
                    ]);
                    
                    // Insert order items and update stock
                    foreach ($order_items as $item) {
                        // Insert order item
                        $insert_item = $conn->prepare("INSERT INTO `order_items` (order_id, product_id, qty, price) VALUES (?,?,?,?)");
                        $insert_item->execute([$order_id, $item['product_id'], $item['qty'], $item['price']]);
                        
                        // Update product stock
                        $update_stock = $conn->prepare("UPDATE `products` SET stock = stock - ? WHERE id = ? AND stock >= ?");
                        $result = $update_stock->execute([$item['qty'], $item['product_id'], $item['qty']]);
                        
                        if (!$result || $update_stock->rowCount() == 0) {
                            throw new Exception("Insufficient stock for product ID: {$item['product_id']}");
                        }
                    }
                    
                    // Clear cart based on user type
                    if (!$is_guest) {
                        $delete_cart = $conn->prepare("DELETE FROM `cart` WHERE user_id = ?");
                        $delete_cart->execute([$user_id]);
                    } else {
                        $_SESSION['cart'] = [];
                    }
                    
                    $conn->commit();
                    
                    // Show success message with buttons
                    echo '
                    <script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>
                    <script>
                        swal({
                            title: "Order Placed!",
                            text: "Your order has been placed successfully!",
                            icon: "success",
                            buttons: {
                                continue: {
                                    text: "Continue Shopping",
                                    value: "continue",
                                },
                                orders: {
                                    text: "View Orders",
                                    value: "orders",
                                },
                            },
                        }).then((value) => {
                            if (value === "continue") {
                                window.location.href = "home.php";
                            } else {
                                window.location.href = "order.php";
                            }
                        });
                    </script>';
                    exit();
                }
                catch(Exception $e) {
                    $conn->rollBack();
                    error_log('Error placing order: ' . $e->getMessage());
                    $warning_msg[] = 'Error processing your order: ' . $e->getMessage();
                }
            }
        } catch(PDOException $e) {
            error_log('Error fetching cart: ' . $e->getMessage());
            $warning_msg[] = 'Error processing your cart. Please try again.';
            $validation_passed = false;
        }
    }
}

// Display cart summary
include 'components/user_header.php';
