            </form>
            <div class="summary">
                <h3>my bag</h3>
                <div class="box-container">
                    <?php
                    $grand_total = 0;
                    if (!$is_guest) {
                        // User is logged in, fetch from database
                        $select_cart = $conn->prepare("SELECT c.*, p.name, p.price, p.thumb_one FROM `cart` c JOIN `products` p ON c.product_id = p.id WHERE c.user_id=?");
                        $select_cart->execute([$user_id]);
                        if ($select_cart->rowCount() > 0) {
                            while ($fetch_cart = $select_cart->fetch(PDO::FETCH_ASSOC)) {
                                $sub_total = ($fetch_cart['qty'] * $fetch_cart['price']);
                                $grand_total += $sub_total;
                                ?>
                                <div class="flex">
                                    <img src="uploaded_files/<?= $fetch_cart['thumb_one']; ?>" class="image">
                                    <div>
                                        <h3 class="name"><?= $fetch_cart['name']; ?></h3>
                                        <p class="price">$<?= $fetch_cart['price']; ?> X <?= $fetch_cart['qty']; ?></p>
                                    </div>
                                </div>
                                <?php
                            }
                        }
                    } else {
                        // Guest user, fetch from session cart
                        if (isset($_SESSION['cart']) && is_array($_SESSION['cart']) && !empty($_SESSION['cart'])) {
                            foreach ($_SESSION['cart'] as $product_id) {
                                $select_products = $conn->prepare("SELECT * FROM products WHERE id=?");
                                $select_products->execute([$product_id]);
                                if ($select_products->rowCount() > 0) {
                                    $product = $select_products->fetch(PDO::FETCH_ASSOC);
                                    // For guests, default quantity is 1
                                    $qty = 1;
                                    $sub_total = $qty * $product['price'];
                                    $grand_total += $sub_total;
                                    ?>
                                    <div class="flex">
                                        <img src="uploaded_files/<?= $product['thumb_one']; ?>" class="image">
                                        <div>
                                            <h3 class="name"><?= $product['name']; ?></h3>
                                            <p class="price">$<?= $product['price']; ?> X <?= $qty; ?></p>
                                        </div>
                                    </div>
                                    <?php
                                }
                            }
                        }
                    }
                    ?>
                </div>
                <div class="grand-total">
                    <span>total amount payable:</span>$<?= $grand_total; ?>/-
                </div>
            </div>
